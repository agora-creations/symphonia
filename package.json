{
  "name": "symphonia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build:packages": "pnpm -r --filter './packages/**' build",
    "dev": "pnpm build:packages && pnpm --parallel --filter @symphonia/daemon --filter @symphonia/web dev",
    "build": "pnpm build:packages && pnpm --filter @symphonia/daemon build && pnpm --filter @symphonia/web build",
    "test": "pnpm build:packages && pnpm -r --filter './packages/**' --filter @symphonia/daemon --filter @symphonia/desktop test",
    "lint": "eslint apps packages --max-warnings=0",
    "format": "prettier --write apps packages README.md GOAL_PROGRESS.md",
    "harness:scan": "tsx packages/core/src/harness-cli.ts",
    "desktop:dev": "pnpm --filter @symphonia/desktop dev",
    "desktop:build": "pnpm --filter @symphonia/desktop build",
    "desktop:package": "pnpm --filter @symphonia/desktop package",
    "desktop:inspect-artifact": "pnpm --filter @symphonia/desktop inspect-artifact",
    "desktop:smoke": "pnpm --filter @symphonia/desktop test",
    "validate": "pnpm test && pnpm lint && pnpm build && pnpm desktop:build && git diff --check && pnpm harness:scan --path .",
    "validate:packages": "pnpm build:packages && pnpm -r --filter './packages/**' test",
    "validate:web": "pnpm --filter @symphonia/web lint && pnpm --filter @symphonia/web build",
    "validate:daemon": "pnpm --filter @symphonia/daemon lint && pnpm --filter @symphonia/daemon test && pnpm --filter @symphonia/daemon build",
    "validate:desktop": "pnpm desktop:build && pnpm desktop:smoke",
    "validate:harness": "pnpm harness:scan --path .",
    "validate:packaging": "pnpm desktop:package && pnpm desktop:inspect-artifact",
    "validate:ci": "pnpm test && pnpm lint && pnpm build && pnpm desktop:build && pnpm harness:scan --path . && git diff --check"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^25.7.0",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^15.15.0",
    "prettier": "^3.7.3",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "electron", "esbuild", "sharp"]
  }
}
