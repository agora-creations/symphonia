{
  "name": "symphonia",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build:packages": "pnpm -r --filter './packages/**' build",
    "dev": "pnpm build:packages && pnpm --parallel --filter @symphonia/daemon --filter @symphonia/web dev",
    "build": "pnpm build:packages && pnpm --filter @symphonia/daemon build && pnpm --filter @symphonia/web build",
    "test": "pnpm build:packages && pnpm -r --filter './packages/**' --filter @symphonia/daemon test",
    "lint": "eslint apps packages --max-warnings=0",
    "format": "prettier --write apps packages README.md GOAL_PROGRESS.md"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^22.16.5",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "prettier": "^3.7.3",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "sharp"]
  }
}
